{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "build-HITL",
  "agent": {
    "build-HITL": {
      "mode": "primary",
      "description": "Agent for coding, asks for permission when making edits.",
      "permission": {
        "write": "ask",
        "edit": "ask",
        "read": "allow",
        "bash": "allow",
      }
    }
  }
}
