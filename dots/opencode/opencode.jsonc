{
  "$schema": "https://opencode.ai/config.json",
  "default_agent":"plan",
  //"model": "openai/chatgpt-5.2-codex",
  "autoupdate": false,
  "agent": {
    "plan": {
      //"model": "openai/chatgpt-5.2-codex",
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "lsp": "allow",
        "doom_loop": "ask",
      }
    },
    "build":{
      "edit": "ask",
    }
  }
}
