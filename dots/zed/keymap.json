// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
      "space t t": "workspace::NewTerminal",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // "j k": "vim::NormalBefore"
      "space o": null,
      // Window operations (SPC w)
      "space w l": "workspace::ActivatePaneRight",
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w s": "pane::SplitDown",
      "space w v": "pane::SplitRight",
      "space w c": "pane::CloseActiveItem",
      // Open operations (SPC o)
      "space o t": "terminal_panel::Toggle",
      // Project operations (SPC p)
      "space p f": "file_finder::Toggle",
      "space p p": "projects::OpenRecent",
      // Code operations (SPC c)
      "space c a": "editor::ToggleCodeActions",
      "space c d": "editor::GoToDefinition",
      "space c D": "editor::FindAllReferences",
      "space c f": "editor::Format",
      "space c r": "editor::Rename",
      "space c x": "diagnostics::Deploy",
      "shift k": "editor::ShowSignatureHelp",
    },
  },
  {
    "context": "Editor && vim_mode == normal && (vim_operator == none || vim_operator == n) && !VimWaiting",
    "bindings": {
      "space f s": "workspace::Save",
      "space p t": "workspace::ToggleLeftDock",
      "space s p": "file_finder::Toggle",
    },
  },
]
